# Lulula Bridge — variables de entorno
# Copia a server/.env y completa para SMS real

PORT=8787
HOST=0.0.0.0

# IRC (Libera por defecto)
IRC_HOST=irc.libera.chat
IRC_PORT=6697
IRC_TLS=true

# ─── SMS / OTP ───────────────────────────────────────────────
# Sin Twilio → modo DEV: el OTP se imprime en la consola del servidor
SMS_DEV_MODE=true

# Twilio (producción) — https://console.twilio.com
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# App (opcional — raíz del proyecto Expo)
# EXPO_PUBLIC_WS_HOST=localhost
# EXPO_PUBLIC_WS_PORT=8787
